---
layout: null
permalink: /assets/data/ask-vri-current-offerings.json
---

{
  "generated_at": {{ site.time | date_to_xmlschema | jsonify }},
  "source": "Generated from VRI Jekyll data files.",
  "important_note": "This file contains current public-facing VRI pathway, session, and proposal information for Ask VRI. Published policies, signed agreements, and direct written communications from VRI may govern specific cases.",

  "pathways": {
    "circles": {
      "name": "Circles",
      "tier": "Tier I",
      "cohort_size": {{ site.data.pathways.circles.cohort_size | jsonify }},
      "duration": {{ site.data.pathways.circles.duration | jsonify }},
      "price": {{ site.data.pathways.circles.price | jsonify }},
      "public_terms": {{ site.data.pathways.circles.public_terms | jsonify }}
    },
    "groups": {
      "name": "Groups",
      "tier": "Tier II",
      "cohort_size": {{ site.data.pathways.groups.cohort_size | jsonify }},
      "duration": {{ site.data.pathways.groups.duration | jsonify }},
      "price": {{ site.data.pathways.groups.price | jsonify }},
      "public_terms": {{ site.data.pathways.groups.public_terms | jsonify }}
    },
    "research_extension": {
      "name": "Research Extension",
      "availability": {{ site.data.pathways.research_extension.availability | jsonify }},
      "duration": {{ site.data.pathways.research_extension.duration | jsonify }},
      "price": {{ site.data.pathways.research_extension.price | jsonify }}
    }
  },

  "sessions": {
    "circles": [
      {% assign active_circle_sessions = site.data.sessions.circles.sessions | where: "active", true %}
      {% for session in active_circle_sessions %}
      {
        "id": {{ session.id | jsonify }},
        "label": {% if active_circle_sessions.size > 1 %}{{ session.label | jsonify }}{% else %}{{ "Current Session" | jsonify }}{% endif %},
        "data_label": {{ session.label | jsonify }},
        "start_date": {{ session.start_date | jsonify }},
        "end_date": {{ session.end_date | jsonify }},
        "registration_deadline": {{ session.registration_deadline | jsonify }},
        "duration": {{ session.duration | jsonify }},
        "offerings_count": {{ session.offerings_count | jsonify }},
        "proposals_data": {{ session.proposals_data | jsonify }}
      }{% unless forloop.last %},{% endunless %}
      {% endfor %}
    ],
    "groups": [
      {% assign active_group_sessions = site.data.sessions.groups.sessions | where: "active", true %}
      {% for session in active_group_sessions %}
      {
        "id": {{ session.id | jsonify }},
        "label": {% if active_group_sessions.size > 1 %}{{ session.label | jsonify }}{% else %}{{ "Current Session" | jsonify }}{% endif %},
        "data_label": {{ session.label | jsonify }},
        "start_date": {{ session.start_date | jsonify }},
        "end_date": {{ session.end_date | jsonify }},
        "registration_deadline": {{ session.registration_deadline | jsonify }},
        "duration": {{ session.duration | jsonify }},
        "offerings_count": {{ session.offerings_count | jsonify }},
        "proposals_data": {{ session.proposals_data | jsonify }}
      }{% unless forloop.last %},{% endunless %}
      {% endfor %}
    ]
  },

  "current_offerings": {
    "circles": [
      {% assign circle_output_count = 0 %}
      {% assign active_circle_sessions = site.data.sessions.circles.sessions | where: "active", true %}
      {% for session in active_circle_sessions %}
        {% assign session_proposals_unsorted = site.data.proposals[session.proposals_data] %}
        {% if session_proposals_unsorted %}
          {% assign session_proposals = session_proposals_unsorted | sort: "sort_order" %}
          {% for proposal in session_proposals %}
          {% if circle_output_count > 0 %},{% endif %}
          {
            "pathway": "Circles",
            "session_id": {{ session.id | jsonify }},
            "session_label": {% if active_circle_sessions.size > 1 %}{{ session.label | jsonify }}{% else %}{{ "Current Session" | jsonify }}{% endif %},
            "data_session_label": {{ session.label | jsonify }},
            "start_date": {{ session.start_date | jsonify }},
            "registration_deadline": {{ session.registration_deadline | jsonify }},
            "sort_order": {{ proposal.sort_order | default: forloop.index | jsonify }},
            "proposal_session_label": {{ proposal.session_label | jsonify }},
            "title": {{ proposal.title | jsonify }},
            "topic_area": {{ proposal.topic_area | jsonify }},
            "mentor": {
              "name": {{ proposal.mentor.name | jsonify }},
              "lines": {{ proposal.mentor.lines | jsonify }}
            },
            "schedule": {
              "timezone": {{ proposal.schedule.timezone | jsonify }},
              "details": {{ proposal.schedule.details | jsonify }}
            },
            "technology": {
              "platform": {{ proposal.technology.platform | jsonify }},
              "code_used": {{ proposal.technology.code_used | jsonify }},
              "needed": {{ proposal.technology.needed | jsonify }}
            },
            "project_overview": {{ proposal.project_overview | jsonify }},
            "background": {{ proposal.background | jsonify }},
            "possible_extension": {{ proposal.possible_extension | jsonify }},
            "references": {{ proposal.references | jsonify }}
          }
          {% assign circle_output_count = circle_output_count | plus: 1 %}
          {% endfor %}
        {% endif %}
      {% endfor %}
    ],

    "groups": [
      {% assign group_output_count = 0 %}
      {% assign active_group_sessions = site.data.sessions.groups.sessions | where: "active", true %}
      {% for session in active_group_sessions %}
        {% assign session_proposals_unsorted = site.data.proposals[session.proposals_data] %}
        {% if session_proposals_unsorted %}
          {% assign session_proposals = session_proposals_unsorted | sort: "sort_order" %}
          {% for proposal in session_proposals %}
          {% if group_output_count > 0 %},{% endif %}
          {
            "pathway": "Groups",
            "session_id": {{ session.id | jsonify }},
            "session_label": {% if active_group_sessions.size > 1 %}{{ session.label | jsonify }}{% else %}{{ "Current Session" | jsonify }}{% endif %},
            "data_session_label": {{ session.label | jsonify }},
            "start_date": {{ session.start_date | jsonify }},
            "registration_deadline": {{ session.registration_deadline | jsonify }},
            "sort_order": {{ proposal.sort_order | default: forloop.index | jsonify }},
            "proposal_session_label": {{ proposal.session_label | jsonify }},
            "title": {{ proposal.title | jsonify }},
            "topic_area": {{ proposal.topic_area | jsonify }},
            "mentor": {
              "name": {{ proposal.mentor.name | jsonify }},
              "lines": {{ proposal.mentor.lines | jsonify }}
            },
            "schedule": {
              "timezone": {{ proposal.schedule.timezone | jsonify }},
              "details": {{ proposal.schedule.details | jsonify }}
            },
            "technology": {
              "platform": {{ proposal.technology.platform | jsonify }},
              "code_used": {{ proposal.technology.code_used | jsonify }},
              "needed": {{ proposal.technology.needed | jsonify }}
            },
            "project_overview": {{ proposal.project_overview | jsonify }},
            "background": {{ proposal.background | jsonify }},
            "possible_extension": {{ proposal.possible_extension | jsonify }},
            "references": {{ proposal.references | jsonify }}
          }
          {% assign group_output_count = group_output_count | plus: 1 %}
          {% endfor %}
        {% endif %}
      {% endfor %}
    ]
  }
}
